{
  "rewrites": [
    {
      "source": "/app",
      "destination": "https://bamboo-appweb.vercel.app/"
    },
    {
      "source": "/app/(.*)",
      "destination": "https://bamboo-appweb.vercel.app/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install"
}